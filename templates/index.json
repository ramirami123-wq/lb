    "custom_liquid_xbBcm3": {
      "type": "custom-liquid",
      "name": "Custom liquid",
      "settings": {
        "custom_liquid": "<style>\n  .glowly-page * { box-sizing: border-box; }\n  .glowly-page { font-family: 'Inter', system-ui, -apple-system, sans-serif; color: #1A1A1A; line-height: 1.6; }\n  .glowly-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }\n  \n  /* HERO */\n  .glowly-hero { background: #FCE4EC; padding: 100px 24px; text-align: center; border-radius: 0; margin-bottom: 0; }\n  .glowly-hero-subhead { color: #1A1A1A; font-size: 13px; letter-spacing: 4px; font-weight: 500; margin-bottom: 20px; text-transform: uppercase; }\n  .glowly-hero h1 { font-family: 'Playfair Display', Georgia, serif; font-size: 64px; line-height: 1.1; margin: 0 0 24px 0; color: #1A1A1A; font-weight: 400; letter-spacing: -1px; }\n  .glowly-hero p { font-size: 18px; color: #3D3D3D; max-width: 580px; margin: 0 auto 40px auto; }\n  .glowly-btn { display: inline-block; background: #1A1A1A; color: #FFFFFF !important; padding: 18px 48px; text-decoration: none; border-radius: 0; font-weight: 500; letter-spacing: 2px; font-size: 13px; text-transform: uppercase; transition: 0.2s; border: 2px solid #1A1A1A; }\n  .glowly-btn:hover { background: #FFFFFF; color: #1A1A1A !important; }\n  .glowly-hero-img { max-width: 320px; margin: 40px auto 0 auto; display: block; }\n  \n  /* BESTSELLER */\n  .glowly-bestseller { padding: 100px 24px; text-align: center; background: #FFFFFF; }\n  .glowly-section-title { font-family: 'Playfair Display', Georgia, serif; font-size: 42px; color: #1A1A1A; margin: 0 0 12px 0; font-weight: 400; }\n  .glowly-section-sub { color: #888; font-size: 16px; margin-bottom: 50px; font-style: italic; }\n  .glowly-product-card { max-width: 380px; margin: 0 auto; background: #FFFFFF; border: 1px solid #F5D5DD; border-radius: 12px; overflow: hidden; transition: 0.2s; }\n  .glowly-product-card:hover { box-shadow: 0 8px 24px rgba(232, 165, 184, 0.2); }\n  .glowly-product-card img { width: 100%; height: 320px; object-fit: cover; background: #FCE4EC; }\n  .glowly-product-info { padding: 24px; text-align: center; }\n  .glowly-product-info h3 { font-family: 'Playfair Display', serif; font-size: 20px; margin: 0 0 8px 0; }\n  .glowly-product-info .price { color: #E8A5B8; font-size: 18px; font-weight: 600; margin-bottom: 16px; }\n  \n  /* MARQUEE */\n  .glowly-marquee { background: #1A1A1A; overflow: hidden; padding: 18px 0; white-space: nowrap; }\n  .glowly-marquee-track { display: inline-block; animation: scroll 25s linear infinite; color: #FFFFFF; font-size: 13px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; }\n  .glowly-marquee-track span { margin: 0 30px; }\n  @keyframes scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }\n  \n  .glowly-marquee-pink { background: #FCE4EC; color: #1A1A1A; }\n  .glowly-marquee-pink .glowly-marquee-track { color: #1A1A1A; }\n  \n  /* ABOUT */\n  .glowly-about { padding: 100px 24px; background: #FCE4EC; text-align: center; }\n  .glowly-about .glowly-container { max-width: 800px; }\n  .glowly-about p { font-size: 17px; color: #3D3D3D; margin-bottom: 24px; line-height: 1.8; }\n  \n  /* WHY SHOP */\n  .glowly-why { padding: 100px 24px; background: #FFFFFF; }\n  .glowly-why-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 24px; max-width: 1100px; margin: 0 auto; }\n  .glowly-why-card { text-align: center; padding: 32px 20px; background: #FCE4EC; border-radius: 12px; }\n  .glowly-why-card .icon { font-size: 36px; margin-bottom: 16px; }\n  .glowly-why-card h4 { font-family: 'Playfair Display', serif; font-size: 18px; margin: 0 0 8px 0; color: #1A1A1A; }\n  .glowly-why-card p { font-size: 14px; color: #3D3D3D; margin: 0; line-height: 1.6; }\n  \n  /* FAQ */\n  .glowly-faq { padding: 100px 24px; background: #FFFFFF; }\n  .glowly-faq .glowly-container { max-width: 800px; }\n  .glowly-faq details { background: #FCE4EC; border-radius: 8px; padding: 20px 24px; margin-bottom: 12px; cursor: pointer; transition: 0.2s; }\n  .glowly-faq details[open] { background: #F5D5DD; }\n  .glowly-faq summary { font-weight: 600; color: #1A1A1A; font-size: 15px; outline: none; list-style: none; position: relative; padding-right: 30px; }\n  .glowly-faq summary::-webkit-details-marker { display: none; }\n  .glowly-faq summary::after { content: '+'; position: absolute; right: 0; top: 0; font-size: 22px; color: #1A1A1A; }\n  .glowly-faq details[open] summary::after { content: '−'; }\n  .glowly-faq p { margin: 14px 0 0 0; color: #3D3D3D; line-height: 1.7; font-size: 14px; }\n  \n  /* DIVIDER */\n  .glowly-divider { text-align: center; padding: 40px 0; }\n  .glowly-divider span { color: #1A1A1A; font-size: 12px; letter-spacing: 6px; font-family: serif; }\n  \n  /* CLOSING */\n  .glowly-closing { background: #1A1A1A; color: #FFFFFF; padding: 100px 24px; text-align: center; }\n  .glowly-closing h2 { font-family: 'Playfair Display', serif; font-size: 42px; margin: 0 0 16px 0; font-weight: 400; color: #FFFFFF; }\n  .glowly-closing p { font-size: 17px; color: #FCE4EC; margin-bottom: 32px; max-width: 500px; margin-left: auto; margin-right: auto; }\n  .glowly-closing .glowly-btn { background: #FCE4EC; color: #1A1A1A !important; border-color: #FCE4EC; }\n  .glowly-closing .glowly-btn:hover { background: transparent; color: #FCE4EC !important; border-color: #FCE4EC; }\n  \n  /* RESPONSIVE */\n  @media (max-width: 768px) {\n    .glowly-hero { padding: 60px 20px; }\n    .glowly-hero h1 { font-size: 38px; }\n    .glowly-section-title { font-size: 32px; }\n    .glowly-closing h2 { font-size: 32px; }\n  }\n</style>\n\n<div class=\"glowly-page\">\n\n  <!-- HERO -->\n  <section class=\"glowly-hero\">\n    <div class=\"glowly-container\">\n      <div class=\"glowly-hero-subhead\">Cordless · Travel-Ready · USB Rechargeable</div>\n      <h1>Sleek Hair. Anywhere You Are.</h1>\n      <p>The mini wireless straightener that fits in your bag and your busy life. Salon-quality smoothness, on the go.</p>\n      <a href=\"/products/REPLACE-WITH-YOUR-PRODUCT-HANDLE\" class=\"glowly-btn\">Shop Now</a>\n    </div>\n  </section>\n\n  <!-- MARQUEE -->\n  <div class=\"glowly-marquee\">\n    <div class=\"glowly-marquee-track\">\n      <span>✨ CORDLESS HAIR STYLER</span>\n      <span>🎀 USB RECHARGEABLE</span>\n      <span>💕 TRAVEL-READY DESIGN</span>\n      <span>🌸 SALON SMOOTHNESS ANYWHERE</span>\n      <span>✨ CORDLESS HAIR STYLER</span>\n      <span>🎀 USB RECHARGEABLE</span>\n      <span>💕 TRAVEL-READY DESIGN</span>\n      <span>🌸 SALON SMOOTHNESS ANYWHERE</span>\n    </div>\n  </div>\n\n  <!-- BESTSELLER -->\n  <section class=\"glowly-bestseller\">\n    <div class=\"glowly-container\">\n      <h2 class=\"glowly-section-title\">The Glowly Bestseller 💕</h2>\n      <p class=\"glowly-section-sub\">Mini in size. Major in glow.</p>\n      <a href=\"/products/REPLACE-WITH-YOUR-PRODUCT-HANDLE\" style=\"text-decoration: none; color: inherit;\">\n        <div class=\"glowly-product-card\">\n          <img src=\"REPLACE-WITH-PRODUCT-IMAGE-URL\" alt=\"Mini Wireless Hair Straightener\">\n          <div class=\"glowly-product-info\">\n            <h3>Mini Wireless Hair Straightener</h3>\n            <div class=\"price\">$19.99</div>\n            <span class=\"glowly-btn\">Shop Now</span>\n          </div>\n        </div>\n      </a>\n    </div>\n  </section>\n\n  <!-- ABOUT -->\n  <section class=\"glowly-about\">\n    <div class=\"glowly-container\">\n      <h2 class=\"glowly-section-title\">About Glowly 🎀</h2>\n      <p>At Glowly, we believe beauty should travel with you — not weigh you down. Our mission is to bring you sleek, smart, beautifully designed beauty essentials that fit into your real life: your purse, your morning rush, your weekend getaway.</p>\n      <p>We focus on tools that combine clever technology, elegant design, and effortless ease — so you can look and feel your best, anywhere life takes you.</p>\n      <p style=\"font-style: italic; color: #1A1A1A; font-weight: 500;\">Glowly — Effortless Beauty. Everyday Glow. 💕</p>\n    </div>\n  </section>\n\n  <!-- MARQUEE PINK -->\n  <div class=\"glowly-marquee glowly-marquee-pink\">\n    <div class=\"glowly-marquee-track\">\n      <span>💎 SLEEK HAIR IN SECONDS</span>\n      <span>🎀 GENTLE ON ALL HAIR TYPES</span>\n      <span>✨ READY TO STYLE IN 30 SECONDS</span>\n      <span>🌸 LOVED BY 2,000+ WOMEN</span>\n      <span>💎 SLEEK HAIR IN SECONDS</span>\n      <span>🎀 GENTLE ON ALL HAIR TYPES</span>\n      <span>✨ READY TO STYLE IN 30 SECONDS</span>\n      <span>🌸 LOVED BY 2,000+ WOMEN</span>\n    </div>\n  </div>\n\n  <!-- WHY SHOP -->\n  <section class=\"glowly-why\">\n    <div class=\"glowly-container\">\n      <h2 class=\"glowly-section-title\" style=\"text-align: center;\">Why Shop Glowly 💕</h2>\n      <p class=\"glowly-section-sub\" style=\"text-align: center;\">Because the best beauty rituals fit your life.</p>\n      <div class=\"glowly-why-grid\">\n        <div class=\"glowly-why-card\">\n          <div class=\"icon\">✨</div>\n          <h4>Free Delivery</h4>\n          <p>Free shipping on orders over $40 — straight to your door.</p>\n        </div>\n        <div class=\"glowly-why-card\">\n          <div class=\"icon\">⚡</div>\n          <h4>USB Rechargeable</h4>\n          <p>Charge once. Style anywhere. No batteries needed.</p>\n        </div>\n        <div class=\"glowly-why-card\">\n          <div class=\"icon\">✈️</div>\n          <h4>Travel-Ready</h4>\n          <p>Sleek, compact design that fits in any bag.</p>\n        </div>\n        <div class=\"glowly-why-card\">\n          <div class=\"icon\">🛡️</div>\n          <h4>Built to Last</h4>\n          <p>Quality design backed by our customer-first guarantee.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- FAQ -->\n  <section class=\"glowly-faq\">\n    <div class=\"glowly-container\">\n      <h2 class=\"glowly-section-title\" style=\"text-align: center;\">Frequently Asked</h2>\n      <p class=\"glowly-section-sub\" style=\"text-align