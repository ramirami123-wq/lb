ong>194+<\/strong> Customers\n  <\/div>\n<\/div>"}},"title":{"type":"title","settings":{"show_products_rating":true,"show_products_rating_average":false,"show_custom_badges":false}},"custom_liquid_BKzFYK":{"type":"custom_liquid","settings":{"custom_liquid":"<section class=\"sale-timer\" aria-label=\"Sale countdown timer\">\n  <style>\n    .sale-timer{\n      width:100%;\n      padding:22px 12px;\n      display:flex;\n      justify-content:center;\n      background:##CB572A;\n      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;\n    }\n    .sale-timer__wrap{\n      text-align:center;\n    }\n    .sale-timer__label{\n      font-size:24px;\n      font-weight:500;\n      color:#111;\n      margin:0 0 14px 0;\n      line-height:1.1;\n    }\n\n    .sale-timer__row{\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      gap:10px;\n    }\n\n    .sale-timer__box{\n      width:88px;\n      height:68px;\n      background:#B88933;\n      color:#fff;\n      border-radius:6px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      font-size:34px;\n      font-weight:700;\n      letter-spacing:1px;\n      font-variant-numeric: tabular-nums;\n    }\n\n    .sale-timer__colon{\n      font-size:32px;\n      font-weight:700;\n      color:#ff2a2a;\n      line-height:1;\n      transform: translateY(-1px);\n      user-select:none;\n    }\n\n    @media (max-width:420px){\n      .sale-timer__label{ font-size:20px; }\n      .sale-timer__box{ width:72px; height:58px; font-size:30px; }\n      .sale-timer__colon{ font-size:28px; }\n      .sale-timer__row{ gap:8px; }\n    }\n  <\/style>\n\n  <div class=\"sale-timer__wrap\">\n    <div class=\"sale-timer__label\">Hurry! Sale ends in<\/div>\n\n    <div class=\"sale-timer__row\" role=\"timer\" aria-live=\"polite\">\n      <div class=\"sale-timer__box\" id=\"st-hours\">00<\/div>\n      <div class=\"sale-timer__colon\">:<\/div>\n      <div class=\"sale-timer__box\" id=\"st-mins\">00<\/div>\n      <div class=\"sale-timer__colon\">:<\/div>\n      <div class=\"sale-timer__box\" id=\"st-secs\">00<\/div>\n    <\/div>\n  <\/div>\n\n  <script>\n    (function () {\n      const durationHours = 12; \/\/ change if needed\n      const endAt = Date.now() + durationHours * 60 * 60 * 1000;\n\n      const h = document.getElementById(\"st-hours\");\n      const m = document.getElementById(\"st-mins\");\n      const s = document.getElementById(\"st-secs\");\n\n      const pad = n => String(n).padStart(2, \"0\");\n\n      function update(){\n        let diff = endAt - Date.now();\n        if(diff < 0) diff = 0;\n\n        const total = Math.floor(diff \/ 1000);\n        h.textContent = pad(Math.floor(total \/ 3600));\n        m.textContent = pad(Math.floor((total % 3600) \/ 60));\n        s.textContent = pad(total % 60);\n\n        if(diff === 0) clearInterval(timer);\n      }\n\n      update();\n      const timer = setInterval(update, 1000);\n    })();\n  <\/script>\n<\/section>"}},"custom_liquid_gAaUw4":{"type":"custom_liquid","settings":{"custom_liquid":"<div style=\"padding: 12px; text-align: left; background-color: #f9f9f9; font-size: 15px; border-radius: 12px; margin-top: 10px; margin-bottom: 10px; line-height: 1.6;\">\n\n<span style=\"font-weight: bold;\">💧 Deep Hydration Boost<\/span> – Infuses skin with long-lasting moisture for a plump, refreshed look.<br><br>\n\n<span style=\"font-weight: bold;\">✨ Collagen + Niacinamide<\/span> – Helps improve skin elasticity while brightening and evening out tone.<br><br>\n\n<span style=\"font-weight: bold;\">🧴 Lightweight Jelly Texture<\/span> – Absorbs quickly without feeling greasy or heavy on the skin.<br><br>\n\n<span style=\"font-weight: bold;\">🌿 Skin Barrier Support<\/span> – Strengthens and protects your skin for a healthy, glowing finish.\n\n<\/div>"}},"variant_picker":{"type":"variant_picker","settings":{"picker_type":"button","color_picker":true,"color_picker_use_variants":false,"vari