        "custom_liquid": "<style>\n  .glowly-product * { box-sizing: border-box; }\n  .glowly-product { font-family: 'Inter', system-ui, sans-serif; color: #1A1A1A; line-height: 1.6; }\n  .glowly-product-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }\n\n  /* Marquee */\n  .glowly-product .marquee { background: #1A1A1A; overflow: hidden; padding: 18px 0; white-space: nowrap; }\n  .glowly-product .marquee-track { display: inline-block; animation: glowlyScroll 25s linear infinite; color: #FFFFFF; font-size: 13px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; }\n  .glowly-product .marquee-track span { margin: 0 30px; }\n  @keyframes glowlyScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }\n\n  /* Trust row */\n  .glowly-product .trust { padding: 60px 24px; background: #FCE4EC; }\n  .glowly-product .trust-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 32px; text-align: center; }\n  .glowly-product .trust-item .icon { font-size: 32px; margin-bottom: 12px; }\n  .glowly-product .trust-item h4 { font-family: 'Playfair Display', Georgia, serif; font-size: 16px; margin: 0 0 6px 0; font-weight: 500; }\n  .glowly-product .trust-item p { font-size: 13px; color: #3D3D3D; margin: 0; }\n\n  /* Benefit blocks */\n  .glowly-product .benefit { padding: 100px 24px; }\n  .glowly-product .benefit-pink { background: #FCE4EC; }\n  .glowly-product .benefit-white { background: #FFFFFF; }\n  .glowly-product .benefit-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; max-width: 1100px; margin: 0 auto; }\n  .glowly-product .benefit-inner.reverse { direction: rtl; }\n  .glowly-product .benefit-inner.reverse > * { direction: ltr; }\n  .glowly-product .benefit img { width: 100%; height: auto; border-radius: 12px; display: block; }\n  .glowly-product .benefit .caption { color: #E8A5B8; font-size: 12px; letter-spacing: 3px; text-transform: uppercase; font-weight: 600; margin-bottom: 12px; }\n  .glowly-product .benefit h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 36px; line-height: 1.2; margin: 0 0 20px 0; font-weight: 400; }\n  .glowly-product .benefit p { font-size: 16px; color: #3D3D3D; line-height: 1.7; margin: 0 0 16px 0; }\n\n  /* Compare */\n  .glowly-product .compare { padding: 100px 24px; background: #FFFFFF; }\n  .glowly-product .compare h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 36px; text-align: center; margin: 0 0 12px 0; font-weight: 400; }\n  .glowly-product .compare-sub { text-align: center; color: #888; font-style: italic; margin-bottom: 40px; }\n  .glowly-product .compare table { width: 100%; max-width: 800px; margin: 0 auto; border-collapse: collapse; }\n  .glowly-product .compare th, .glowly-product .compare td { padding: 16px; text-align: center; border-bottom: 1px solid #F5D5DD; }\n  .glowly-product .compare th { background: #FCE4EC; font-family: 'Playfair Display', Georgia, serif; font-size: 16px; font-weight: 500; }\n  .glowly-product .compare th:first-child, .glowly-product .compare td:first-child { text-align: left; }\n  .glowly-product .compare .yes { color: #4CAF50; font-size: 20px; font-weight: 700; }\n  .glowly-product .compare .no { color: #C9A0A0; font-size: 18px; font-weight: 700; }\n\n  /* How to */\n  .glowly-product .howto { padding: 100px 24px; background: #FCE4EC; }\n  .glowly-product .howto h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 36px; text-align: center; margin: 0 0 50px 0; font-weight: 400; }\n  .glowly-product .howto-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 32px; max-width: 1000px; margin: 0 auto; }\n  .glowly-product .howto-step { text-align: center; }\n  .glowly-product .howto-step .num { font-family: 'Playfair Display', Georgia, serif; font-size: 48px; color: #E8A5B8; line-height: 1; margin-bottom: 12px; font-weight: 400; }\n  .glowly-product .howto-step h4 { font-family: 'Playfair Display', Georgia, serif; font-size: 18px; margin: 0 0 8px 0; font-weight: 500; }\n  .glowly-product .howto-step p { font-size: 14px; color: #3D3D3D; line-height: 1.6; margin: 0; }\n\n  /* Reviews */\n  .glowly-product .reviews { padding: 100px 24px; background: #FFFFFF; }\n  .glowly-product .reviews h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 36px; text-align: center; margin: 0 0 12px 0; font-weight: 400; }\n  .glowly-product .reviews-sub { text-align: center; color: #888; font-style: italic; margin-bottom: 40px; }\n  .glowly-product .reviews-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; max-width: 1100px; margin: 0 auto; }\n  .glowly-product .review { background: #FCE4EC; padding: 28px; border-radius: 12px; }\n  .glowly-product .review .stars { color: #E8A5B8; margin-bottom: 12px; font-size: 14px; letter-spacing: 2px; }\n  .glowly-product .review p { font-size: 14px; color: #3D3D3D; line-height: 1.7; margin: 0 0 16px 0; font-style: italic; }\n  .glowly-product .review .author { font-size: 13px; font-weight: 600; color: #1A1A1A; }\n\n  /* FAQ */\n  .glowly-product .faq { padding: 100px 24px; background: #FFFFFF; }\n  .glowly-product .faq-inner { max-width: 800px; margin: 0 auto; padding: 0 24px; }\n  .glowly-product .faq h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 36px; text-align: center; margin: 0 0 12px 0; font-weight: 400; }\n  .glowly-product .faq-sub { text-align: center; color: #888; font-style: italic; margin-bottom: 40px; }\n  .glowly-product .faq details { background: #FCE4EC; border-radius: 8px; padding: 20px 24px; margin-bottom: 12px; cursor: pointer; transition: 0.2s; }\n  .glowly-product .faq details[open] { background: #F5D5DD; }\n  .glowly-product .faq summary { font-weight: 600; color: #1A1A1A; font-size: 15px; outline: none; list-style: none; position: relative; padding-right: 30px; }\n  .glowly-product .faq summary::-webkit-details-marker { display: none; }\n  .glowly-product .faq summary::after { content: '+'; position: absolute; right: 0; top: 0; font-size: 22px; color: #1A1A1A; }\n  .glowly-product .faq details[open] summary::after { content: '−'; }\n  .glowly-product .faq p { margin: 14px 0 0 0; color: #3D3D3D; line-height: 1.7; font-size: 14px; }\n\n  /* Final CTA */\n  .glowly-product .final { background: #1A1A1A; color: #FFFFFF; padding: 100px 24px; text-align: center; }\n  .glowly-product .final h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 42px; margin: 0 0 16px 0; font-weight: 400; color: #FFFFFF; }\n  .glowly-product .final p { font-size: 17px; color: #FCE4EC; margin: 0 auto 32px auto; max-width: 500px; }\n  .glowly-product .final-form { margin: 0; }\n  .glowly-product .final-form button { display: inline-block; background: #FCE4EC; color: #1A1A1A; padding: 18px 48px; border: 2px solid #FCE4EC; font-weight: 500; letter-spacing: 2px; font-size: 13px; text-transform: uppercase; cursor: pointer; transition: 0.2s; font-family: inherit; }\n  .glowly-product .final-form button:hover { background: transparent; color: #FCE4EC; }\n  .glowly-product .final-note { font-size: 13px; color: #FCE4EC; margin-top: 16px; opacity: 0.7; letter-spacing: 1px; }\n\n  @media (max-width: 768px) {\n    .glowly-product .benefit { padding: 60px 20px; }\n    .glowly-product .benefit-inner { grid-template-columns: 1fr; gap: 32px; }\n    .glowly-product .benefit-inner.reverse { direction: ltr; }\n    .glowly-product .benefit h2 { font-size: 28px; }\n    .glowly-product .compare th, .glowly-product .compare td { padding: 10px; font-size: 13px; }\n    .glowly-product .howto, .glowly-product .reviews, .glowly-product .faq, .glowly-product .compare { padding: 60px 20px; }\n    .glowly-product .final h2 { font-size: 32px; }\n  }\n</style>\n\n<div class=\"glowly-product\">\n\n  <!-- Marquee -->\n  <div class=\"marquee\">\n    <div class=\"marquee-track\">\n      <span>✨ FREE SHIPPING OVER $40</span>\n      <span>🎀 14-DAY MONEY-BACK GUARANTEE</span>\n      <span>💕 LOVED BY 2,000+ WOMEN</span>\n      <span>🌸 USB RECHARGEABLE</span>\n      <span>✨ FREE SHIPPING OVER $40</span>\n      <span>🎀 14-DAY MONEY-BACK GUARANTEE</span>\n      <span>💕 LOVED BY 2,000+ WOMEN</span>\n      <span>🌸 USB RECHARGEABLE</span>\n    </div>\n  </div>\n\n  <!-- Trust row -->\n  <section class=\"trust\">\n    <div class=\"glowly-product-container\">\n      <div class=\"trust-grid\">\n        <div class=\"trust-item\">\n          <div class=\"icon\">⚡</div>\n          <h4>30-Second Heat-Up</h4>\n          <p>Ready before your morning coffee.</p>\n        </div>\n        <div class=\"trust-item\">\n          <div class=\"icon\">✈️</div>\n          <h4>Travel-Ready</h4>\n          <p>Fits in any bag. Cordless freedom.</p>\n        </div>\n        <div class=\"trust-item\">\n          <div class=\"icon\">🛡️</div>\n          <h4>Safe for All Hair</h4>\n          <p>Even heat. No damage.</p>\n        </div>\n        <div class=\"trust-item\">\n          <div class=\"icon\">💕</div>\n          <h4>Effortlessly Cute</h4>\n          <p>As good as it looks.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Benefit 1 -->\n  <section class=\"benefit benefit-white\">\n    <div class=\"benefit-inner\">\n      <div>\n        <img src=\"{{ product.featured_image | image_url: width: 800 }}\" alt=\"{{ product.title | escape }}\">\n      </div>\n      <div>\n        <div class=\"caption\">Sleek hair, anywhere</div>\n        <h2>From bedhead to brunch-ready in five minutes.</h2>\n        <p>The Glowly mini heats in 30 seconds and glides through your hair with even, gentle warmth. Perfect for taming flyaways, smoothing frizz, or restyling between meetings.</p>\n        <p>No more lugging a full-size flat iron in your weekender. This one slips into your purse.</p>\n      </div>\n    </div>\n  </section>\n\n  <!-- Benefit 2 -->\n  <section class=\"benefit benefit-pink\">\n    <div class=\"benefit-inner reverse\">\n      <div>\n        {% if product.images.size > 1 %}\n          <img src=\"{{ product.images[1] | image_url: width: 800 }}\" alt=\"{{ product.title | escape }}\">\n        {% else %}\n          <img src=\"{{ product.featured_image | image_url: width: 800 }}\" alt=\"{{ product.title | escape }}\">\n        {% endif %}\n      </div>\n      <div>\n        <div class=\"caption\">USB-rechargeable</div>\n        <h2>Charge once. Style anywhere. No outlet needed.</h2>\n        <p>A full USB charge powers multiple styling sessions — refresh your look at a coffee shop, an airport, or a hotel bathroom with the worst lighting in the world.</p>\n        <p>USB cable included. Plug into any laptop, power bank, or wall adapter.</p>\n      </div>\n    </div>\n  </section>\n\n  <!-- Compare -->\n  <section class=\"compare\">\n    <div class=\"glowly-product-container\">\n      <h2>Glowly vs Your Old Flat Iron</h2>\n      <p class=\"compare-sub\">Five reasons this is the one that travels with you.</p>\n      <table>\n        <thead>\n          <tr>\n            <th></th>\n            <th>Glowly Mini</th>\n            <th>Old Flat Iron</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr><td>Cordless · USB rechargeable</td><td><span class=\"yes\">✓</span></td><td><span class=\"no\">✗</span></td></tr>\n          <tr><td>Fits in a purse</td><td><span class=\"yes\">✓</span></td><td><span class=\"no\">✗</span></td></tr>\n          <tr><td>30-second heat-up</td><td><span class=\"yes\">✓</span></td><td><span class=\"no\">✗</span></td></tr>\n          <tr><td>Gentle even heat</td><td><span class=\"yes\">✓</span></td><td><span class=\"no\">✗</span></td></tr>\n          <tr><td>Salon-quality finish</td><td><span class=\"yes\">✓</span></td><td><span class=\"yes\">✓</span></td></tr>\n        </tbody>\n      </table>\n    </div>\n  </section>\n\n  <!-- How to -->\n  <section class=\"howto\">\n    <div class=\"glowly-product-container\">\n      <h2>How to Glow ✨</h2>\n      <div class=\"howto-grid\">\n        <div class=\"howto-step\">\n          <div class=\"num\">1</div>\n          <h4>Charge & Power On</h4>\n          <p>Plug into any USB. One full charge = multiple sessions.</p>\n        </div>\n        <div class=\"howto-step\">\n          <div class=\"num\">2</div>\n          <h4>Wait 30 Seconds</h4>\n          <p>The indicator light tells you when it's ready.</p>\n        </div>\n        <div class=\"howto-step\">\n          <div class=\"num\">3</div>\n          <h4>Glide & Smooth</h4>\n          <p>Work in small sections. One pass is usually enough.</p>\n        </div>\n        <div class=\"howto-step\">\n          <div class=\"num\">4</div>\n          <h4>Slip & Go</h4>\n          <p>Cools quickly. Drop it in your bag — out the door.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Reviews -->\n  <section class=\"reviews\">\n    <div class=\"glowly-product-container\">\n      <h2>Real Women. Real Glow. 💕</h2>\n      <p class=\"reviews-sub\">2,000+ happy customers and counting.</p>\n      <div class=\"reviews-grid\">\n        <div class=\"review\">\n          <div class=\"stars\">★★★★★</div>\n          <p>\"Lives in my work bag. Quick touch-ups before meetings every morning. Game changer.\"</p>\n          <div class=\"author\">— Layla M.</div>\n        </div>\n        <div class=\"review\">\n          <div class=\"stars\">★★★★★</div>\n          <p>\"Took it on a 10-day trip and didn't miss my full-size straightener once. So fast to heat up.\"</p>\n          <div class=\"author\">— Nour S.</div>\n        </div>\n        <div class=\"review\">\n          <div class=\"stars\">★★★★★</div>\n          <p>\"My hair is thick and curly — I was skeptical. It handles it. Smooths flyaways perfectly.\"</p>\n          <div class=\"author\">— Yasmine K.</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- FAQ -->\n  <section class=\"faq\">\n    <div class=\"faq-inner\">\n      <h2>Frequently Asked</h2>\n      <p class=\"faq-sub\">Everything you need to know before you glow.</p>\n      <details>\n        <summary>Is it really cordless?</summary>\n        <p>Yes — charge it once via USB and style anywhere. No outlets, no cords. Perfect for travel, the gym, or quick touch-ups before going out.</p>\n      </details>\n      <details>\n        <summary>How long does the battery last?</summary>\n        <p>A full charge powers multiple styling sessions. Plug it back in with the included USB cable when it runs low.</p>\n      </details>\n      <details>\n        <summary>Will it damage my hair?</summary>\n        <p>Designed with even heat distribution to be gentle on hair — far less harsh than traditional flat irons. Glide through small sections for the smoothest, safest results.</p>\n      </details>\n      <details>\n        <summary>Does it work on all hair types?</summary>\n        <p>Yes — works on all hair types and lengths. Fine, thick, straight, curly. Perfect for smoothing flyaways, straightening sections, or restyling on the go.</p>\n      </details>\n      <details>\n        <summary>How long does it take to heat up?</summary>\n        <p>About 30 seconds. Turn it on, wait a moment, and you're ready to style.</p>\n      </details>\n      <details>\n        <summary>What's your return policy?</summary>\n        <p>14-day money-back guarantee. If you're not glowing, send it back for a full refund. No questions.</p>\n      </details>\n    </div>\n  </section>\n\n  <!-- Final CTA -->\n  <section class=\"final\">\n    <h2>Ready to Glow?</h2>\n    <p>Join thousands of women who never leave home without their Glowly.</p>\n    <form action=\"/cart/add\" method=\"post\" enctype=\"multipart/form-data\" class=\"final-form\">\n      <input type=\"hidden\" name=\"id\" value=\"{{ product.selected_or_first_available_variant.id }}\">\n      <button type=\"submit\">Add to Bag — {{ product.price | money }}</button>\n    </form>\n    <div class=\"final-note\">FREE SHIPPING OVER $40 · 14-DAY RETURNS</div>\n  </section>\n\n</div>"
      }
